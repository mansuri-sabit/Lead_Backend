# ─── Required in Production ───────────────────────────────────────────────────
NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/data-scraper
JWT_SECRET=generate-a-64-char-random-string-here
FRONTEND_URL=https://your-frontend-domain.onrender.com

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=5001
MAX_CONCURRENT_SCRAPERS=3
JWT_EXPIRY=24h

# MongoDB fallback (standard connection string, no SRV)
# MONGODB_URI_STANDARD=mongodb://USER:PASSWORD@host1:27017,host2:27017/data-scraper

# DNS fix for Windows (if MongoDB SRV lookup fails)
USE_PUBLIC_DNS=1
# DNS_SERVERS=8.8.8.8,1.1.1.1

# ─── Scraper Tuning (all optional) ───────────────────────────────────────────
# SCRAPER_MAX_ADS=100
# SCRAPER_SCROLL_DELAY=600
# SCRAPER_MAX_SCROLL_ATTEMPTS=5000
# SCRAPER_BATCH_SIZE=50
# SCRAPER_NAV_TIMEOUT=20000
# SCRAPER_ELEMENT_TIMEOUT=10000

# Facebook Filter Bot (Playwright) — optional session file (see npm run filter-bot:save-session)
# FILTER_BOT_STORAGE_STATE=fb-filter-bot-storage.json
# FILTER_BOT_HEADLESS=0
# FILTER_BOT_DEBUG=1
